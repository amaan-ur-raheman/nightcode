{
    "name": "nightcode",
    "version": "1.0.0",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "bun run dev:server",
        "dev:cli": "bun run --watch packages/cli/src/index.tsx",
        "dev:server": "bun run --hot packages/server/src/index.ts",
        "build:cli": "bun run --filter @nightcode/cli build",
        "build": "bun run --filter '*' build",
        "link:cli": "bun run build:cli && cd packages/cli && bun link",
        "start": "mprocs",
        "test": "bun run --filter '*' test",
        "test:cli": "cd packages/cli && bun run test",
        "test:server": "cd packages/server && bun run test",
        "typecheck": "bun run --filter '*' typecheck",
        "format": "bun x prettier --write .",
        "lint": "bun x eslint .",
        "postinstall": "bun run --filter @nightcode/database db:generate"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    }
}
