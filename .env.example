API_URL=your-api-url
PORT=5959

# DATABASE
DATABASE_URL=your-database-url

# POSTGRES (required for docker-compose — do NOT use default values in production)
# Generate a strong password: openssl rand -base64 32
# Set via .env file, shell export, or override: POSTGRES_PASSWORD=secret docker compose up
POSTGRES_PASSWORD=

# DATABASE POOL (PostgreSQL only)
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=5000
# DB_STATEMENT_TIMEOUT=30000

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NIM_API_KEY=
NIM_API_KEY_SUBAGENT= # Optional: separate API key for subagents to avoid rate limits
GROQ_API_KEY=
OPENCODE_API_KEY= # OpenCode Zen — get key at https://opencode.ai/auth
KILO_API_KEY= # Kilo Gateway — get key at https://kilo.ai
CLOUDFLARE_API_KEY= # Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID= # Cloudflare Account ID (from dashboard URL)
ZENMUX_API_KEY= # ZenMux — get key at https://zenmux.ai
MISTRAL_API_KEY= # Mistral AI — get key at https://console.mistral.ai
DASHSCOPE_API_KEY= # Qwen (DashScope) — get key at https://dashscope.console.aliyun.com
PERPLEXITY_API_KEY= # Perplexity AI — get key at https://perplexity.ai/settings/api
COHERE_API_KEY= # Cohere — get key at https://dashboard.cohere.com
HF_API_KEY= # Hugging Face — get key at https://huggingface.co/settings/tokens
ZHIPU_API_KEY= # Zhipu AI (GLM) — get key at https://open.bigmodel.cn
MOONSHOT_API_KEY= # Moonshot (Kimi) — get key at https://platform.moonshot.cn
XAI_API_KEY= # xAI (Grok) — get key at https://console.x.ai
MINIMAX_API_KEY= # MiniMax — get key at https://platform.minimax.io
SAMBANOVA_API_KEY= # SambaNova — get key at https://cloud.sambanova.ai
SILICONFLOW_API_KEY= # SiliconFlow — get key at https://cloud.siliconflow.cn
DEEPINFRA_API_TOKEN= # DeepInfra — get key at https://deepinfra.com
NOVITA_API_KEY= # Novita AI — get key at https://novita.ai
NEBIUS_API_KEY= # Nebius — get key at https://nebius.studio
CLINE_API_KEY= # Cline — get key at https://app.cline.bot

# CLERK
CLERK_OAUTH_CLIENT_SECRET=
CLERK_OAUTH_CLIENT_ID=
CLERK_FRONTEND_API=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# POLAR
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_SERVER=sandbox
POLAR_CREDITS_METER_ID=