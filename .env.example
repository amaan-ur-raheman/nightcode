API_URL=your-api-url
PORT=5959

# DATABASE
DATABASE_URL=your-database-url

# POSTGRES (required for docker-compose — do NOT use default values in production)
# Generate a strong password: openssl rand -base64 32
# Set via .env file, shell export, or override: POSTGRES_PASSWORD=secret docker compose up
POSTGRES_PASSWORD=

# DATABASE POOL (PostgreSQL only)
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=5000
# DB_STATEMENT_TIMEOUT=30000

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NIM_API_KEY=
NIM_API_KEY_SUBAGENT= # Optional: separate API key for subagents to avoid rate limits
GROQ_API_KEY=
OPENCODE_API_KEY= # OpenCode Zen — get key at https://opencode.ai/auth
KILO_API_KEY= # Kilo Gateway — get key at https://kilo.ai

# CLERK
CLERK_OAUTH_CLIENT_SECRET=
CLERK_OAUTH_CLIENT_ID=
CLERK_FRONTEND_API=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# POLAR
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_SERVER=sandbox
POLAR_CREDITS_METER_ID=