generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Session {
    id        String   @id @default(cuid())
    userId    String
    title     String

    messages  Json     @default("[]")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
}