{
    "name": "@nightcode/server",
    "type": "module",
    "private": true,
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "postinstall": "bun run --cwd ../database db:generate",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.82",
        "@ai-sdk/google": "^3.0.80",
        "@ai-sdk/groq": "^3.0.39",
        "@ai-sdk/openai": "^3.0.69",
        "@ai-sdk/openai-compatible": "^2.0.48",
        "@ai-sdk/provider": "^3.0.10",
        "@ai-sdk/provider-utils": "^4.0.27",
        "@clerk/backend": "^3.4.14",
        "@hono/zod-validator": "^0.8.0",
        "@nightcode/database": "workspace:*",
        "@nightcode/shared": "workspace:*",
        "@polar-sh/sdk": "^0.47.1",
        "ai": "^6.0.193",
        "dotenv": "^17.4.2",
        "hono": "^4.12.23",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@vitest/coverage-v8": "^4.1.8",
        "vitest": "^3.1.1"
    }
}
